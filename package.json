{
  "name": "muso",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev":       "vite",
    "build":     "vite build",
    "preview":   "vite preview",

    "build:web": "vite build --config vite.config.web.js",
    "build:cap": "vite build --config vite.config.cap.js",

    "cap:init":    "npx cap init MUSO app.muso.network --web-dir dist-cap",
    "cap:add:ios": "npx cap add ios",
    "cap:add:and": "npx cap add android",
    "cap:sync":    "npx cap sync",
    "cap:ios":     "npm run build:cap && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build:cap && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@capacitor/core": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/share": "^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
